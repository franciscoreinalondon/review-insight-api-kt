      { "author": { "uri": { "label": "https://itunes.apple.com/gb/reviews/id436961329" }, "name": { "label": "jemavc" }, "label": "" }, "updated": { "label": "2026-02-13T03:34:58-07:00" }, "im:rating": { "label": "5" }, "im:version": { "label": "1.206.0" }, "id": { "label": "13744283987" }, "title": { "label": "Efficient" }, "content": { "label": "Easy and effective to use", "attributes": { "type": "text" } }, "link": { "attributes": { "rel": "related", "href": "https://itunes.apple.com/gb/review?id=1324011914&type=Purple%20Software" } }, "im:voteSum": { "label": "0" }, "im:contentType": { "attributes": { "term": "Application", "label": "Application" } }, "im:voteCount": { "label": "0" } },
      { "author": { "uri": { "label": "https://itunes.apple.com/gb/reviews/id122090181" }, "name": { "label": "jamon8" }, "label": "" }, "updated": { "label": "2026-02-12T07:30:39-07:00" }, "im:rating": { "label": "1" }, "im:version": { "label": "1.205.0" }, "id": { "label": "13741471042" }, "title": { "label": "Non stop loan emails" }, "content": { "label": "I know I’m eligible for a loan, stop spamming me with those emails!", "attributes": { "type": "text" } }, "link": { "attributes": { "rel": "related", "href": "https://itunes.apple.com/gb/review?id=1324011914&type=Purple%20Software" } }, "im:voteSum": { "label": "0" }, "im:contentType": { "attributes": { "term": "Application", "label": "Application" } }, "im:voteCount": { "label": "0" } },
      { "author": { "uri": { "label": "https://itunes.apple.com/gb/reviews/id1194053063" }, "name": { "label": "avfrubj" }, "label": "" }, "updated": { "label": "2026-02-12T04:37:21-07:00" }, "im:rating": { "label": "1" }, "im:version": { "label": "1.205.0" }, "id": { "label": "13740952216" }, "title": { "label": "Not user friendly" }, "content": { "label": "Terrible experience. Trying to reinvest with zopa and am sent constantly back and forth between the website and the app, having to log in again every time. I think I’ve ended up withdrawing my money completely from them, although at this point I’m still confused, so who knows?", "attributes": { "type": "text" } }, "link": { "attributes": { "rel": "related", "href": "https://itunes.apple.com/gb/review?id=1324011914&type=Purple%20Software" } }, "im:voteSum": { "label": "0" }, "im:contentType": { "attributes": { "term": "Application", "label": "Application" } }, "im:voteCount": { "label": "0" } },
      { "author": { "uri": { "label": "https://itunes.apple.com/gb/reviews/id472970235" }, "name": { "label": "Marcin19837" }, "label": "" }, "updated": { "label": "2026-02-11T19:13:15-07:00" }, "im:rating": { "label": "1" }, "im:version": { "label": "1.205.0" }, "id": { "label": "13739746664" }, "title": { "label": "Not a very good bank" }, "content": { "label": "There are constant delays in payments. When you contact support, they tell you to check the sender's details, which is pointless because my other banks are connected to Zopa and the transfers are from my account, so there's no way there could be a mistake. It's time to close my Zopa account because these errors keep happening.", "attributes": { "type": "text" } }, "link": { "attributes": { "rel": "related", "href": "https://itunes.apple.com/gb/review?id=1324011914&type=Purple%20Software" } }, "im:voteSum": { "label": "0" }, "im:contentType": { "attributes": { "term": "Application", "label": "Application" } }, "im:voteCount": { "label": "0" } },
      { "author": { "uri": { "label": "https://itunes.apple.com/gb/reviews/id1889832690" }, "name": { "label": "El jefe 187" }, "label": "" }, "updated": { "label": "2026-02-11T11:08:43-07:00" }, "im:rating": { "label": "1" }, "im:version": { "label": "1.205.0" }, "id": { "label": "13738591447" }, "title": { "label": "Rubbish" }, "content": { "label": "I made the account for 5 days I got a transfer of £300 and they suspended my account. Now I’m being told I have to wait 4-6weeks for my money. It’s £300 mate not 20k. I don’t understand", "attributes": { "type": "text" } }, "link": { "attributes": { "rel": "related", "href": "https://itunes.apple.com/gb/review?id=1324011914&type=Purple%20Software" } }, "im:voteSum": { "label": "0" }, "im:contentType": { "attributes": { "term": "Application", "label": "Application" } }, "im:voteCount": { "label": "0" } },
      { "author": { "uri": { "label": "https://itunes.apple.com/gb/reviews/id661115028" }, "name": { "label": "tassos2816" }, "label": "" }, "updated": { "label": "2026-02-06T13:13:12-07:00" }, "im:rating": { "label": "5" }, "im:version": { "label": "1.205.0" }, "id": { "label": "13720629558" }, "title": { "label": "Zopa Bank" }, "content": { "label": "Excellent App very easy to follow", "attributes": { "type": "text" } }, "link": { "attributes": { "rel": "related", "href": "https://itunes.apple.com/gb/review?id=1324011914&type=Purple%20Software" } }, "im:voteSum": { "label": "0" }, "im:contentType": { "attributes": { "term": "Application", "label": "Application" } }, "im:voteCount": { "label": "0" } },
      { "author": { "uri": { "label": "https://itunes.apple.com/gb/reviews/id33401675" }, "name": { "label": "eddiechilli" }, "label": "" }, "updated": { "label": "2026-02-05T09:01:15-07:00" }, "im:rating": { "label": "1" }, "im:version": { "label": "1.205.0" }, "id": { "label": "13716279143" }, "title": { "label": "Account Opening" }, "content": { "label": "Great account opening process. Totally digital, fast and easy. But, then the trouble begins; there is no information to say that transfers are limited to £1k for the first week after account opening. I have to cover a\nMortgage\nPayment from saving after the operator\nRefused to process the transfer.\nMy app is not\nUp to date with transactions after several days. I get fraud controls\nOn payments for as little as ten pounds. Call centre is not open during hours I have available to\nSort things out, when you do get through\nyou can’t understand the staff. The thing about these Neo Banks is the just don’t have the experience or backing to provide a good service. I closed the account.", "attributes": { "type": "text" } }, "link": { "attributes": { "rel": "related", "href": "https://itunes.apple.com/gb/review?id=1324011914&type=Purple%20Software" } }, "im:voteSum": { "label": "0" }, "im:contentType": { "attributes": { "term": "Application", "label": "Application" } }, "im:voteCount": { "label": "0" } },
      { "author": { "uri": { "label": "https://itunes.apple.com/gb/reviews/id20305170" }, "name": { "label": "mkyni" }, "label": "" }, "updated": { "label": "2026-02-05T03:58:38-07:00" }, "im:rating": { "label": "1" }, "im:version": { "label": "1.205.0" }, "id": { "label": "13715333043" }, "title": { "label": "* SERIOUS IT APP FAILURES *" }, "content": { "label": "£ This new bank cannot be trusted with your money £ \n\nThe app is riddled with bugs which can cause your money to disappear. \n\nFor example, I’d thought I’d transferred money in the app, but the money never arrived at its destination. Customer Service is woefully in adequate, although they did confirm App bugs. \n\n*** AVOID ***", "attributes": { "type": "text" } }, "link": { "attributes": { "rel": "related", "href": "https://itunes.apple.com/gb/review?id=1324011914&type=Purple%20Software" } }, "im:voteSum": { "label": "0" }, "im:contentType": { "attributes": { "term": "Application", "label": "Application" } }, "im:voteCount": { "label": "0" } },
      { "author": { "uri": { "label": "https://itunes.apple.com/gb/reviews/id232405092" }, "name": { "label": "Kellied2012" }, "label": "" }, "updated": { "label": "2026-02-04T00:08:32-07:00" }, "im:rating": { "label": "5" }, "im:version": { "label": "1.204.1" }, "id": { "label": "13711119732" }, "title": { "label": "10/10 app" }, "content": { "label": "Easy to use, never any issues, quick transfers between accounts and great saving rates.", "attributes": { "type": "text" } }, "link": { "attributes": { "rel": "related", "href": "https://itunes.apple.com/gb/review?id=1324011914&type=Purple%20Software" } }, "im:voteSum": { "label": "0" }, "im:contentType": { "attributes": { "term": "Application", "label": "Application" } }, "im:voteCount": { "label": "0" } },
      { "author": { "uri": { "label": "https://itunes.apple.com/gb/reviews/id1183021260" }, "name": { "label": "Nera242" }, "label": "" }, "updated": { "label": "2026-02-03T06:03:58-07:00" }, "im:rating": { "label": "5" }, "im:version": { "label": "1.204.1" }, "id": { "label": "13708377623" }, "title": { "label": "Excellent" }, "content": { "label": "Love the app and features", "attributes": { "type": "text" } }, "link": { "attributes": { "rel": "related", "href": "https://itunes.apple.com/gb/review?id=1324011914&type=Purple%20Software" } }, "im:voteSum": { "label": "0" }, "im:contentType": { "attributes": { "term": "Application", "label": "Application" } }, "im:voteCount": { "label": "0" } },
      { "author": { "uri": { "label": "https://itunes.apple.com/gb/reviews/id474385125" }, "name": { "label": "frencsy007" }, "label": "" }, "updated": { "label": "2026-02-03T03:56:45-07:00" }, "im:rating": { "label": "1" }, "im:version": { "label": "1.204.1" }, "id": { "label": "13707999998" }, "title": { "label": "I cannot access my money 3rd day in a row!!" }, "content": { "label": "Customer service says due to technical difficulties .. I cannot access my money neither of my accounts on ZOPA. There are constant issues with the app and I cannot withdraw or transfer at all. Rates are very good but they need to update their tech asap as their system crushes more times then working. When I called them they said nothing can be done until the technical team sort the issues out. I have invoices to pay and I will get penalties due to this!", "attributes": { "type": "text" } }, "link": { "attributes": { "rel": "related", "href": "https://itunes.apple.com/gb/review?id=1324011914&type=Purple%20Software" } }, "im:voteSum": { "label": "0" }, "im:contentType": { "attributes": { "term": "Application", "label": "Application" } }, "im:voteCount": { "label": "0" } },
      { "author": { "uri": { "label": "https://itunes.apple.com/gb/reviews/id724692248" }, "name": { "label": "Lolllypop826373" }, "label": "" }, "updated": { "label": "2026-02-01T22:34:03-07:00" }, "im:rating": { "label": "2" }, "im:version": { "label": "1.204.1" }, "id": { "label": "13703648629" }, "title": { "label": "App killing iphone battery" }, "content": { "label": "If you developers would ever open this app on an iphone and keep it open for more than 30 seconds you would realize that the phone heats up so much that you almost have to drop it from your hands. I am sure it is killing the battery and I haven’t got any other single app that would do the same. Would be great if this could be fixed. Pretty shameful", "attributes": { "type": "text" } }, "link": { "attributes": { "rel": "related", "href": "https://itunes.apple.com/gb/review?id=1324011914&type=Purple%20Software" } }, "im:voteSum": { "label": "0" }, "im:contentType": { "attributes": { "term": "Application", "label": "Application" } }, "im:voteCount": { "label": "0" } },
      { "author": { "uri": { "label": "https://itunes.apple.com/gb/reviews/id177295991" }, "name": { "label": "Chickpeas97" }, "label": "" }, "updated": { "label": "2026-01-28T03:39:55-07:00" }, "im:rating": { "label": "3" }, "im:version": { "label": "1.203.0" }, "id": { "label": "13684898885" }, "title": { "label": "New update" }, "content": { "label": "Old version was better. Although the new one looks better I could see instantly how much my repayments would change with every extra repayment. Now you have to wait and it will tell you eventually.", "attributes": { "type": "text" } }, "link": { "attributes": { "rel": "related", "href": "https://itunes.apple.com/gb/review?id=1324011914&type=Purple%20Software" } }, "im:voteSum": { "label": "0" }, "im:contentType": { "attributes": { "term": "Application", "label": "Application" } }, "im:voteCount": { "label": "0" } },
