      { "author": { "uri": { "label": "https://itunes.apple.com/gb/reviews/id638308902" }, "name": { "label": "Mats4025" }, "label": "" }, "updated": { "label": "2026-02-23T23:41:22-07:00" }, "im:rating": { "label": "5" }, "im:version": { "label": "1.207.0" }, "id": { "label": "13783172933" }, "title": { "label": "Mr smith" }, "content": { "label": "Great service easy to use app updates instantly with remaining balance adding money goes straight to you balance not like some where takes the day \nVery handy with the small changes for the cash withdrawals", "attributes": { "type": "text" } }, "link": { "attributes": { "rel": "related", "href": "https://itunes.apple.com/gb/review?id=1324011914&type=Purple%20Software" } }, "im:voteSum": { "label": "0" }, "im:contentType": { "attributes": { "term": "Application", "label": "Application" } }, "im:voteCount": { "label": "0" } },
      { "author": { "uri": { "label": "https://itunes.apple.com/gb/reviews/id577532407" }, "name": { "label": "bungle2324" }, "label": "" }, "updated": { "label": "2026-02-20T10:16:09-07:00" }, "im:rating": { "label": "5" }, "im:version": { "label": "1.207.0" }, "id": { "label": "13770491005" }, "title": { "label": "Brilliant" }, "content": { "label": "Zopa are one of the best banks I’ve had the pleasure of being with. They make everything so easy and convenient. Would recommend to all my friends.", "attributes": { "type": "text" } }, "link": { "attributes": { "rel": "related", "href": "https://itunes.apple.com/gb/review?id=1324011914&type=Purple%20Software" } }, "im:voteSum": { "label": "0" }, "im:contentType": { "attributes": { "term": "Application", "label": "Application" } }, "im:voteCount": { "label": "0" } },
      { "author": { "uri": { "label": "https://itunes.apple.com/gb/reviews/id47712893" }, "name": { "label": "ch7is" }, "label": "" }, "updated": { "label": "2026-02-17T23:00:16-07:00" }, "im:rating": { "label": "2" }, "im:version": { "label": "1.206.0" }, "id": { "label": "13761651203" }, "title": { "label": "Why" }, "content": { "label": "Why no dark mode", "attributes": { "type": "text" } }, "link": { "attributes": { "rel": "related", "href": "https://itunes.apple.com/gb/review?id=1324011914&type=Purple%20Software" } }, "im:voteSum": { "label": "1" }, "im:contentType": { "attributes": { "term": "Application", "label": "Application" } }, "im:voteCount": { "label": "1" } },
      { "author": { "uri": { "label": "https://itunes.apple.com/gb/reviews/id771445308" }, "name": { "label": "Brad616." }, "label": "" }, "updated": { "label": "2026-02-17T17:53:35-07:00" }, "im:rating": { "label": "1" }, "im:version": { "label": "1.206.0" }, "id": { "label": "13760977404" }, "title": { "label": "Worst bank I’ve been with." }, "content": { "label": "I’m extremely disappointed with my experience with Zopa. I withdrew £130 from a cash machine, but the machine only dispensed £120. I reported the issue immediately, expecting it to be investigated properly and the missing £10 refunded.\n\nHowever, Zopa failed to resolve the issue and did not refund the missing amount. Despite explaining that the ATM underpaid me, they did not take meaningful action to correct the error. As a customer, you trust your bank to handle disputes like this fairly and efficiently. especially when it involves an ATM withdrawal discrepancy.\n\nIt’s frustrating to feel like your concerns aren’t taken seriously over what should be a straightforward claim. £10 may not be a large amount to a bank, but it matters to customers. I expected better support and accountability.\n\nBased on this experience, I’m very disappointed in Zopa’s handling of the situation and their lack of customer care.\n\nPlease stay away from this bank. It’s worrying to think that if this happened to someone else for a much larger sum, they might not be covered either.", "attributes": { "type": "text" } }, "link": { "attributes": { "rel": "related", "href": "https://itunes.apple.com/gb/review?id=1324011914&type=Purple%20Software" } }, "im:voteSum": { "label": "0" }, "im:contentType": { "attributes": { "term": "Application", "label": "Application" } }, "im:voteCount": { "label": "0" } },
      { "author": { "uri": { "label": "https://itunes.apple.com/gb/reviews/id39078483" }, "name": { "label": "Tia Chan Lo" }, "label": "" }, "updated": { "label": "2026-02-17T08:58:16-07:00" }, "im:rating": { "label": "5" }, "im:version": { "label": "1.206.0" }, "id": { "label": "13759616821" }, "title": { "label": "Account Set Up" }, "content": { "label": "Setting up was really easy taking only a few minutes", "attributes": { "type": "text" } }, "link": { "attributes": { "rel": "related", "href": "https://itunes.apple.com/gb/review?id=1324011914&type=Purple%20Software" } }, "im:voteSum": { "label": "0" }, "im:contentType": { "attributes": { "term": "Application", "label": "Application" } }, "im:voteCount": { "label": "0" } },
      { "author": { "uri": { "label": "https://itunes.apple.com/gb/reviews/id7835075" }, "name": { "label": "Totocb" }, "label": "" }, "updated": { "label": "2026-02-17T06:12:11-07:00" }, "im:rating": { "label": "1" }, "im:version": { "label": "1.206.0" }, "id": { "label": "13759121880" }, "title": { "label": "Always malfunctioning" }, "content": { "label": "I like the product, but you can only apply through the app, and this is the second time when I click the offer link on the app and am unable to proceed. When you chat/call you have to wait 48 hours for a response from their tech team to fix the issue. Last time their offer ran out so I went elsewhere. They are let down by the glitchy app and their customer service.", "attributes": { "type": "text" } }, "link": { "attributes": { "rel": "related", "href": "https://itunes.apple.com/gb/review?id=1324011914&type=Purple%20Software" } }, "im:voteSum": { "label": "0" }, "im:contentType": { "attributes": { "term": "Application", "label": "Application" } }, "im:voteCount": { "label": "0" } },
