      { "author": { "uri": { "label": "https://itunes.apple.com/gb/reviews/id86120778" }, "name": { "label": "CCM MD" }, "label": "" }, "updated": { "label": "2026-04-09T07:50:55-07:00" }, "im:rating": { "label": "1" }, "im:version": { "label": "1.213.2" }, "id": { "label": "13939547540" }, "title": { "label": "AWEFUL" }, "content": { "label": "Several times my transactions have been held and I’ve had to call them which was both inconvenient and time consuming, but now they’ve locked me out of my account and I can’t access my money!\n\nThe SECOND I can I’m withdrawing it ALL and going back to Monzo. \n\nZopa is NOT good!", "attributes": { "type": "text" } }, "link": { "attributes": { "rel": "related", "href": "https://itunes.apple.com/gb/review?id=1324011914&type=Purple%20Software" } }, "im:voteSum": { "label": "0" }, "im:contentType": { "attributes": { "term": "Application", "label": "Application" } }, "im:voteCount": { "label": "0" } },
      { "author": { "uri": { "label": "https://itunes.apple.com/gb/reviews/id364872687" }, "name": { "label": "Psinintgebutt" }, "label": "" }, "updated": { "label": "2026-04-07T22:21:02-07:00" }, "im:rating": { "label": "1" }, "im:version": { "label": "1.213.2" }, "id": { "label": "13934601344" }, "title": { "label": "Zopa app is great when it works" }, "content": { "label": "App keeps locking up and you have to delete and re download nearly everyday!!", "attributes": { "type": "text" } }, "link": { "attributes": { "rel": "related", "href": "https://itunes.apple.com/gb/review?id=1324011914&type=Purple%20Software" } }, "im:voteSum": { "label": "0" }, "im:contentType": { "attributes": { "term": "Application", "label": "Application" } }, "im:voteCount": { "label": "0" } },
      { "author": { "uri": { "label": "https://itunes.apple.com/gb/reviews/id246917026" }, "name": { "label": "Lord Dragonator" }, "label": "" }, "updated": { "label": "2026-04-06T00:41:06-07:00" }, "im:rating": { "label": "1" }, "im:version": { "label": "1.213.2" }, "id": { "label": "13927850114" }, "title": { "label": "If I could give ZERO stars I would 100%" }, "content": { "label": "The most disgusting credit card company ever been with.\n\nDespite 100% proof of fraud, if you become a victim of fraud while using their card you will NOT get anything sorted out and get told you have to 100% continue payments and will harm you credit score if you do not.\n\nJust had my investigation into the fraud I have experienced denied despite complete proof that I was taken advantage of and 100% proof showing I was over 180 miles away when someone used my stolen card details in person to make 2 purchases, one of which I was able to cancel through text.\n\nIt is and can be proven that I was 180 miles away when this in person transaction took place, yet I am now being forced to pay for clear and obvious fraud.\n\nSuch a shame as I thought they were a reputable company when I looked into them.\n\n100% be aware, if you are a victim of fraud like I have been, you will still be made to pay for it.\n\nSTAY CLEAR OF Zopa", "attributes": { "type": "text" } }, "link": { "attributes": { "rel": "related", "href": "https://itunes.apple.com/gb/review?id=1324011914&type=Purple%20Software" } }, "im:voteSum": { "label": "0" }, "im:contentType": { "attributes": { "term": "Application", "label": "Application" } }, "im:voteCount": { "label": "0" } },
